+++ b/Modules/Renderer/CyphenRendererVulkan/Source/Platform/Linux/Private/Surface.cpp
@@ -1,11 +1,48 @@
-#define VK_USE_PLATFORM_UXIX_KHR
+#define VK_USE_PLATFORM_XLIB_KHR
 
 #include <vulkan/vulkan.h>
 
+#include <X11/Xlib.h>
+
+#include <cstdint>
+
 #include "HAL/Private/Surface.h"
 
+const char* GetVulkanPlatformSurfaceExtensionName()
+{
+	return VK_KHR_XLIB_SURFACE_EXTENSION_NAME;
+}
+
 bool CreateVulkanSurface(
 	VkInstance instance,
 	const NativeWindowInfo& windowInfo,
-	VkSurfaceKHR& outSurface)
+	VkSurfaceKHR* outSurface)
 {
+	if (instance == VK_NULL_HANDLE ||
+		windowInfo.nativeDisplayHandle == nullptr ||
+		windowInfo.nativeWindowHandle == nullptr ||
+		outSurface == nullptr)
+	{
+		return false;
+	}
+
+	Display* display = static_cast<Display*>(windowInfo.nativeDisplayHandle);
+	Window window =
+		static_cast<Window>(reinterpret_cast<std::uintptr_t>(windowInfo.nativeWindowHandle));
+
+	if (window == 0)
+	{
+		return false;
+	}
+
+	XWindowAttributes windowAttributes = {};
+
+	if (XGetWindowAttributes(display, window, &windowAttributes) == 0)
+	{
+		return false;
+	}
+
+	VkXlibSurfaceCreateInfoKHR surfaceCreateInfo = {};
+	surfaceCreateInfo.sType = VK_STRUCTURE_TYPE_XLIB_SURFACE_CREATE_INFO_KHR;
+	surfaceCreateInfo.dpy = display;
+	surfaceCreateInfo.window = window;
+
+	return vkCreateXlibSurfaceKHR(
+		instance,
+		&surfaceCreateInfo,
+		nullptr,
+		outSurface) == VK_SUCCESS;
 }
