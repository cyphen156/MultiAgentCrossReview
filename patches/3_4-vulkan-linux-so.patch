diff --git a/Modules/Renderer/CyphenRendererVulkan/Source/Platform/Linux/Private/Surface.cpp b/Modules/Renderer/CyphenRendererVulkan/Source/Platform/Linux/Private/Surface.cpp
index 0000000..0000000 100644
