# MultiAgentCrossReview is a Windows/PowerShell-facing workbench.
# Do not apply CyphenEngine source LF/no-BOM policy to this repository.
# Project-specific line-ending and encoding policy belongs in Projects/<name>/RULES.md.

# Keep executable PowerShell/command entry points Windows-friendly.
.gitattributes text eol=crlf
.gitignore     text eol=crlf
*.md   text eol=crlf
*.txt  text eol=crlf
*.json text eol=crlf
*.ps1  text eol=crlf
*.cmd  text eol=crlf

# Crash dumps / binaries — never touch
*.stackdump binary
*.exe binary
*.dll binary
*.pdb binary
